{
  "name": "cosmos-vscode",
  "displayName": "Cosmos OS Development",
  "description": "VS Code extension for Cosmos OS kernel development with NativeAOT",
  "version": "1.8.1",
  "publisher": "cosmosos",
  "repository": {
    "type": "git",
    "url": "https://github.com/valentinbreiz/CosmosVsCodeExtension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "cosmos",
    "kernel",
    "os",
    "nativeaot",
    "bare-metal",
    "debugger"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "breakpoints": [
      {
        "language": "csharp"
      }
    ],
    "debuggers": [
      {
        "type": "cosmos-run",
        "label": "Cosmos Run",
        "languages": [
          "csharp"
        ]
      },
      {
        "type": "cosmos-debug",
        "label": "Cosmos: Debug Kernel",
        "languages": [
          "csharp"
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {}
          }
        },
        "initialConfigurations": [
          {
            "name": "Cosmos: Debug Kernel",
            "type": "cosmos-debug",
            "request": "launch"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Cosmos: Debug Kernel",
            "description": "Debug a Cosmos kernel in QEMU with GDB",
            "body": {
              "name": "Cosmos: Debug Kernel",
              "type": "cosmos-debug",
              "request": "launch"
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cosmos",
          "title": "Cosmos OS",
          "icon": "media/cosmos-icon.svg"
        }
      ]
    },
    "views": {
      "cosmos": [
        {
          "id": "cosmos.loading",
          "name": "Loading",
          "type": "webview",
          "when": "!cosmos:initialized"
        },
        {
          "id": "cosmos.welcome",
          "name": "Welcome",
          "when": "cosmos:initialized && !cosmos:isCosmosProject"
        },
        {
          "id": "cosmos.project",
          "name": "Project",
          "when": "cosmos:initialized && cosmos:isCosmosProject"
        },
        {
          "id": "cosmos.tools",
          "name": "Tools",
          "when": "cosmos:initialized && cosmos:isCosmosProject"
        }
      ],
      "debug": [
        {
          "id": "cosmos.kernelThreads",
          "name": "Cosmos Kernel Threads",
          "when": "cosmos:isCosmosProject"
        },
        {
          "id": "cosmos.kernelGC",
          "name": "Cosmos Kernel GC",
          "when": "cosmos:isCosmosProject"
        },
        {
          "id": "cosmos.kernelMemory",
          "name": "Cosmos Kernel Memory",
          "when": "cosmos:isCosmosProject"
        },
        {
          "id": "cosmos.kernelMemoryMap",
          "name": "Cosmos Kernel Memory Map",
          "type": "webview",
          "when": "cosmos:isCosmosProject"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "cosmos.welcome",
        "contents": "Welcome to Cosmos OS Development!\n\nCreate your first bare-metal C# kernel.\n\n[Create Kernel Project](command:cosmos.newProject)\n\nOr open an existing Cosmos project folder.\n\n[Open Folder](command:vscode.openFolder)"
      }
    ],
    "commands": [
      {
        "command": "cosmos.newProject",
        "title": "Create Kernel Project",
        "icon": "$(add)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.checkTools",
        "title": "Check Tools",
        "icon": "$(checklist)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.installTools",
        "title": "Install Tools",
        "icon": "$(cloud-download)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.build",
        "title": "Build Kernel",
        "icon": "$(gear)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.run",
        "title": "Run in QEMU",
        "icon": "$(play)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.debug",
        "title": "Debug in QEMU",
        "icon": "$(debug-alt)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.clean",
        "title": "Clean Build",
        "icon": "$(trash)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.refreshTools",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.projectProperties",
        "title": "Project Properties",
        "icon": "$(settings-gear)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelThreads.copy",
        "title": "Copy Kernel Threads",
        "icon": "$(copy)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelThreads.refresh",
        "title": "Refresh Kernel Threads",
        "icon": "$(refresh)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelGC.copy",
        "title": "Copy Kernel GC",
        "icon": "$(copy)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelGC.refresh",
        "title": "Refresh Kernel GC",
        "icon": "$(refresh)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelMemory.copy",
        "title": "Copy Kernel Memory",
        "icon": "$(copy)",
        "category": "Cosmos"
      },
      {
        "command": "cosmos.kernelMemory.refresh",
        "title": "Refresh Kernel Memory",
        "icon": "$(refresh)",
        "category": "Cosmos"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cosmos.refreshTools",
          "when": "view == cosmos.tools",
          "group": "navigation"
        },
        {
          "command": "cosmos.kernelThreads.refresh",
          "when": "view == cosmos.kernelThreads",
          "group": "navigation@1"
        },
        {
          "command": "cosmos.kernelThreads.copy",
          "when": "view == cosmos.kernelThreads",
          "group": "navigation@2"
        },
        {
          "command": "cosmos.kernelGC.refresh",
          "when": "view == cosmos.kernelGC",
          "group": "navigation@1"
        },
        {
          "command": "cosmos.kernelGC.copy",
          "when": "view == cosmos.kernelGC",
          "group": "navigation@2"
        },
        {
          "command": "cosmos.kernelMemory.refresh",
          "when": "view == cosmos.kernelMemory",
          "group": "navigation@1"
        },
        {
          "command": "cosmos.kernelMemory.copy",
          "when": "view == cosmos.kernelMemory",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "cosmos.build",
          "when": "viewItem == buildAction",
          "group": "inline"
        },
        {
          "command": "cosmos.run",
          "when": "viewItem == runAction",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Cosmos OS",
      "properties": {
        "cosmos.defaultArchitecture": {
          "type": "string",
          "default": "x64",
          "enum": [
            "x64",
            "arm64"
          ],
          "description": "Default target architecture for kernel builds"
        },
        "cosmos.qemuMemory": {
          "type": "string",
          "default": "512M",
          "description": "Memory allocation for QEMU emulator"
        },
        "cosmos.testMode": {
          "type": "string",
          "default": "ci",
          "enum": [
            "ci",
            "dev"
          ],
          "enumDescriptions": [
            "Headless QEMU (faster, no display)",
            "Visual QEMU window (slower, useful for inspecting)"
          ],
          "description": "Mode used by the Testing view when running Cosmos kernel tests"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "dependencies": {
    "glob": "^10.3.0",
    "vscode-debugadapter": "^1.51.0",
    "vscode-debugprotocol": "^1.51.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}
